# -*- coding: utf-8 -*-
"""
入口：python run.py
读配置，再把 状态/大脑/总线/窗口 串起来。
"""
import sys
from PyQt5.QtWidgets import QApplication
from PyQt5.QtCore import QSharedMemory

from pet import log
from pet import config as CFG
from pet.bus import bus
from pet.state import State
from pet.brain import Brain
from pet.window import PetWindow


def main():
    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(False)   # 关窗不退出（托盘还在）

    log.setup()
    log.get("run").info("启动")

    # 单实例锁：已经开着就不再开第二个
    _lock = QSharedMemory("baizhenzhen_deskpet_singleton")
    if not _lock.create(1):
        log.get("run").info("已有实例在运行，退出")
        sys.exit(0)
    app._singleton = _lock        # 挂在 app 上防止被回收，进程退出自动释放

    cfg = CFG.load()
    state = State()
    brain = Brain(state, cfg)
    win = PetWindow(state, brain, bus, cfg)
    win.show()
    sys.exit(app.exec_())


if __name__ == "__main__":
    main()

