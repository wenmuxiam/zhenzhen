# -*- coding: utf-8 -*-
import argparse
from pathlib import Path
import zipfile


EXCLUDED_DIRS = {
    ".pytest_cache",
    "__pycache__",
    "raw",
}
EXCLUDED_PREFIXES = {
    "assets/_gpt_source/",
    "assets/_orig_247/",
    "work/",
}
EXCLUDED_FILENAMES = {
    "save.json",
    "save.json.bak",
}


def _norm_rel(path):
    return path.as_posix()


def _is_excluded(rel):
    parts = rel.split("/")
    if any(part in EXCLUDED_DIRS for part in parts):
        return True
    if any(rel.startswith(prefix) for prefix in EXCLUDED_PREFIXES):
        return True
    name = parts[-1]
    if name in EXCLUDED_FILENAMES:
        return True
    if name.endswith(".bak"):
        return True
    if name.endswith("_chromakey.png"):
        return True
    if name.endswith(".pyc") or name.endswith(".pyo"):
        return True
    return False


def iter_release_files(root):
    root = Path(root).resolve()
    files = []
    for path in root.rglob("*"):
        if not path.is_file():
            continue
        rel = _norm_rel(path.relative_to(root))
        if _is_excluded(rel):
            continue
        files.append(rel)
    return sorted(files)


def build_release_zip(root, output_zip):
    root = Path(root).resolve()
    output_zip = Path(output_zip).resolve()
    output_zip.parent.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(output_zip, "w", zipfile.ZIP_DEFLATED, compresslevel=9) as zf:
        for rel in iter_release_files(root):
            zf.write(root / rel, rel)
    return str(output_zip)


def main():
    parser = argparse.ArgumentParser(description="Build a slim QPet release zip.")
    parser.add_argument("--root", default=".", help="Project root to package.")
    parser.add_argument("--out", required=True, help="Output zip path.")
    args = parser.parse_args()
    output = build_release_zip(args.root, args.out)
    print(output)


if __name__ == "__main__":
    main()

# -*- coding: utf-8 -*-
"""
从绿幕走路序列图(sprite sheet)生成 walk_01..NN 透明帧。
源图放 assets/_gpt_source/walk_source_gpt.png（绿底、N 个迈步姿势横排）。

要点（修正 Codex 版"腿不动很假"的问题）：
- 不按脚底基线焊死、也不按每帧自身包围盒重新居中（那会把腿摆削平）；
  改为【按上半身锚定】：水平用包围盒中心、纵向用头顶对齐 idle，保留完整腿部摆动。
- 叠加【纵向步伐起伏 bob】(一步一颠、2 次/循环) + 轻微左右摆，卖出"在走"的体感。
用法：python build_walk.py     依赖：pillow numpy（复用 align_frames.chroma_key 扣绿）
"""
import os, math, importlib.util
import numpy as np
from PIL import Image

HERE = os.path.dirname(os.path.abspath(__file__))
SRC = os.path.join(HERE, "assets", "_gpt_source", "walk_source_gpt.png")
OUT = os.path.join(HERE, "assets", "anim")
BOB_AMP, SWAY = 5.5, 1.5      # 纵向起伏 / 横向摆动（像素）

_spec = importlib.util.spec_from_file_location("af", os.path.join(HERE, "align_frames.py"))
af = importlib.util.module_from_spec(_spec); _spec.loader.exec_module(af)


def _slice_poses(keyed):
    A = np.asarray(keyed); cols = (A[..., 3] > 40).sum(0) > 5
    segs, i, W = [], 0, len(cols)
    while i < W:
        if cols[i]:
            j = i
            while j < W and cols[j]:
                j += 1
            if j - i > 40:
                segs.append((i, j))
            i = j
        else:
            i += 1
    poses = []
    for x0, x1 in segs:
        sub = keyed.crop((x0, 0, x1, keyed.height))
        sa = np.asarray(sub); sy, sx = np.where(sa[..., 3] > 16)
        poses.append(sub.crop((sx.min(), sy.min(), sx.max() + 1, sy.max() + 1)))
    return poses


def main():
    keyed, _ = af.chroma_key(Image.open(SRC))
    poses = _slice_poses(keyed)
    ia = np.asarray(Image.open(os.path.join(HERE, "assets", "idle.png")).convert("RGBA"))
    iy, ix = np.where(ia[..., 3] > 16)
    head_top, feet_y, cx = int(iy.min()), int(iy.max()), (int(ix.min()) + int(ix.max())) // 2
    CW, CH = ia.shape[1], ia.shape[0]
    scale = (feet_y - head_top) / np.median([p.height for p in poses])
    n = len(poses)
    for i, p in enumerate(poses):
        nw, nh = round(p.width * scale), round(p.height * scale)
        ch = p.resize((nw, nh), Image.LANCZOS)
        cyc = 2 * math.pi * i / n
        dy = BOB_AMP * math.sin(2 * cyc)      # 一步一颠
        dx = SWAY * math.sin(cyc)             # 轻微左右摆
        canvas = Image.new("RGBA", (CW, CH), (0, 0, 0, 0))
        canvas.paste(ch, (int(cx - nw // 2 + dx), int(head_top + dy)), ch)
        canvas.save(os.path.join(OUT, f"walk_{i + 1:02d}.png"))
    print(f"已生成 {n} 帧走路 -> {OUT}/walk_*.png (scale={scale:.3f}, bob={BOB_AMP})")


if __name__ == "__main__":
    main()

# 白真真 · Q版桌宠（立绘/序列帧路线）

一个真正的桌面宠物：透明无边框、始终置顶、可拖动、点击命中角色轮廓、气泡台词、
养成（修炼/投喂/好感/突破境界）、看屏幕陪伴吐槽、久坐/喝水/夜深提醒。
**纯本地、不联网、不调用任何 AI 接口。**

> 当前用的是程序生成的「占位 Q 版立绘」，开箱即可跑。把它换成你的真·Q 版图即可。

---

## 1. 运行

需要 Python 3.10+。

```bash
pip install -r requirements.txt
python run.py
```

- **左键点角色**：戳一下，随机出害羞/傲娇/生气/落泪表情 + 气泡（好感越高越容易害羞/开心）。
- **左键拖动**：把她拖到屏幕任意位置。
- **右键**：菜单——投喂（仙丹/灵果/灵茶）、打赏仙币、开始/结束修炼、摸摸头、逗逗她、显示/隐藏数值、重置、退出。
- **托盘图标**：显示/隐藏、退出。
- 数值会自动存到 `save.json`，下次打开接着养。

关窗不退出（托盘还在），从托盘退出。

---

## 2. 换成你的 Q 版素材（A 路线核心）

把你的图放进 `assets/`，**文件名和尺寸保持一致**即可，无需改代码。
规格（占位图就是按这个画的，可直接当模板对照）：

| 文件名 | 含义 | 表情要点 |
|---|---|---|
| `idle.png`  | 待机（睁眼） | 默认站立 |
| `blink.png` | 眨眼 | 同待机但闭眼，程序会定时闪一下 |
| `talk.png`  | 说话 | 张嘴，用于"逗她/好奇/陪伴"等台词 |
| `happy.png` | 开心 | 笑 + 脸红 |
| `shy.png`   | 害羞 | 脸红 + 撇嘴 |
| `angry.png` | 生气 | 怒眼 + 怒气标记 |
| `cry.png`   | 落泪 | 泪 + 委屈 |
| `love.png`  | 心动 | 大脸红（高好感时用） |

- 尺寸：默认 **247 × 480 px**，**透明背景 PNG**。想换尺寸就改 `assets/manifest.json` 里的 `size`，但所有图要一致。
- 想整体放大缩小：改 `config.json` 的 `scale`（如 1.5）。

### 序列帧动画（已支持，逐帧播放 + 表情过渡）

`manifest.json` 的每个状态现在支持三种写法，可混用，**旧的"一状态一图"完全兼容**：

```jsonc
"states": {
  "idle": "idle.png",                              // ① 单帧（旧写法，照常工作）
  "wave": ["wave_01.png", "wave_02.png"],          // ② 多帧，用顶层默认 fps
  "meditate": {                                     // ③ 完整写法
    "frames": ["anim/meditate_01.png", "...02.png", "...03.png", "...04.png"],
    "fps": 5,                                       // 帧率，覆盖顶层默认
    "loop": true                                    // true 循环 / false 播到末帧停住
  }
}
```

- 顶层 `"fps": 8` 是默认帧率；状态内可单独覆盖。
- 渲染器按**真实时间**推进帧（`int(已播放秒数 * fps) % 帧数`），与 30fps 重绘解耦，换帧率不卡。
- **表情/姿态切换有 200ms 淡入淡出**（旧态淡出叠加新态淡入）。
- 新增两个动画状态：`eat`（吃东西，投喂时触发）、`meditate`（修炼，打坐时触发）。
  缺帧时自动回退到现有单图（`eat→talk`、`meditate→blink`），所以**可以先上代码、后补美术**。
  `assets/anim/` 现已是**真立绘序列帧**（修炼 6 帧呼吸、吃东西 6 帧咀嚼），由绿底原画经
  `align_frames.py` 抠像 + 对齐生成；想换图见下节。

### 用 align_frames.py 由绿底原画生成序列帧

把绿底原画（`修炼.png` / `吃东西张嘴.png` / `吃东西闭嘴.png`）放到 `SRC_DIR`（默认
`/mnt/user-data/uploads`，可用环境变量改），运行：

```bash
pip install pillow numpy
SRC_DIR=./raw python align_frames.py     # 输出 assets/anim/meditate_01..06、eat_01..06
```

脚本会：绿幕抠像 + 去绿边/去发光描边 → 按 `idle.png` 的人物高度/脚底基线/水平中心
**统一缩放对齐**（三姿势共用一个 scale，吃东西张/闭嘴不会忽大忽小）→ 由打坐底图合成
呼吸循环、由张/闭嘴底图合成咀嚼循环。换新原画只需替换 `SRC_DIR` 里三张图重跑即可。

