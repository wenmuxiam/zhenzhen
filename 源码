# -*- coding: utf-8 -*-
"""
align_frames.py —— 把绿底原画规整成桌宠用的透明序列帧。

输入（放在 SRC_DIR）：
    修炼姿势.png         盘腿浮空打坐（眼闭、双手结印）—— 坐姿浮空
    吃东西张嘴.png       张嘴（手边一粒金丹）
    吃东西闭嘴.png       闭嘴咀嚼

做三件事：
    1) 绿幕抠像 + 去绿/去青边（despill），消除发光描边残留；
    2) 对齐到 247×480 透明画布：
         - 吃东西（站姿）按 idle 的身高 / 脚底基线 / 水平中心对齐；
         - 修炼（盘腿浮空坐姿）单独定标、水平居中、底部留白＝悬浮高度（双脚离地），
           过宽的长发在两侧裁掉而非把整个人缩小，保证头/身与 idle 等大；
    3) 由对齐后的底图合成循环帧：
         修炼  -> 6 帧“浮空呼吸”循环（绕身体中心极轻微缩放 + 上下飘浮）
         吃东西-> 6 帧“咀嚼”循环（张/闭嘴底图交替 + 1px 点头）

输出：assets/anim/meditate_01..06.png、assets/anim/eat_01..06.png
用法：python align_frames.py        依赖：pillow numpy
"""
import os, json, math
import numpy as np
from PIL import Image, ImageFilter

HERE = os.path.dirname(os.path.abspath(__file__))
SRC_DIR = os.environ.get("SRC_DIR", "/mnt/user-data/uploads")
ASSET_DIR = os.path.join(HERE, "assets")
ANIM_DIR = os.path.join(ASSET_DIR, "anim")
REF_PNG = os.path.join(ASSET_DIR, "idle.png")   # 对齐基准（已透明）

SOURCES = {
    "meditate": "修炼姿势.png",
    "eat_open": "吃东西张嘴.png",
    "eat_close": "吃东西闭嘴.png",
}

# 绿幕参数：greenness = G - max(R,B)
KEY_LOW = 22     # <=LOW 视为纯前景（alpha=1）
KEY_HIGH = 90    # >=HIGH 视为纯背景（alpha=0），中间线性过渡得到柔边
TIGHT = 60       # 计算人物包围盒用的阈值（略紧，少含外侧绿光）
ERODE = 9        # 向内收缩 alpha 的核大小（去掉人物自带的青/绿发光描边），奇数
# 青/蓝残留处理：cyan = min(G,B) - R（>0 即偏青，绿幕扣掉后发光描边留下的就是它）
CYAN_CUT_LO = 12   # cyan<=LO 不动
CYAN_CUT_HI = 60   # cyan>=HI 直接抠透明（消除强青色光晕）
DESPILL_M = 6      # 去青色调：把 G、B 压到不超过 R+M，残留的青边中和成本色

# 体型对齐：站姿（吃东西）按身高对齐 idle；修炼是"盘腿浮空"坐姿，单独定标+悬浮摆放。
POSE_SCALE = {"eat_open": 1.0, "eat_close": 1.0}
CLIP_BUDGET = 22
# —— 浮空打坐立绘（坐姿紧凑、双脚离地，不走脚底基线对齐）——
MED_SCALE = 0.355       # 按头部/体型贴近 idle 调好；换修炼图后这里微调即可
MED_BOTTOM_GAP = 72     # 人物底部离画布底的留白＝悬浮高度（px）；越大浮得越高


# ---------------- 抠像 ----------------
def chroma_key(im):
    """绿底 RGBA -> 透明 RGBA：绿幕柔边 + 收边去描边 + 去绿/去青残留。"""
    a = np.asarray(im.convert("RGBA")).astype(np.int16)
    r, g, b = a[..., 0], a[..., 1], a[..., 2]
    greenness = g - np.maximum(r, b)
    cyan = np.minimum(g, b) - r            # >0 即偏青（发光描边残留）

    # 1) 绿幕柔边 alpha
    ag = np.clip((KEY_HIGH - greenness) / (KEY_HIGH - KEY_LOW), 0.0, 1.0)
    # 2) 强青色光晕直接抠透明
    ac = np.clip(1.0 - (cyan - CYAN_CUT_LO) / (CYAN_CUT_HI - CYAN_CUT_LO), 0.0, 1.0)
    alpha = ag * ac
    aL = Image.fromarray((alpha * 255).astype(np.uint8), "L")
    if ERODE and ERODE >= 3:
        aL = aL.filter(ImageFilter.MinFilter(ERODE))   # 向内收缩，去掉发光描边
        aL = aL.filter(ImageFilter.GaussianBlur(0.6))  # 轻微羽化，边缘更顺
    alpha = np.asarray(aL).astype(np.float32) / 255.0

    # 3) 颜色去残留：先去绿，再去青（把过量的 G/B 压到本色，消除镶边）
    g2 = np.where(greenness > 0, np.maximum(r, b), g)
    cy2 = np.minimum(g2, b) - r
    g3 = np.where(cy2 > 0, np.minimum(g2, r + DESPILL_M), g2)
    b3 = np.where(cy2 > 0, np.minimum(b, r + DESPILL_M), b)

    out = np.dstack([r, g3, b3, (alpha * 255)]).astype(np.uint8)
    return Image.fromarray(out, "RGBA"), greenness


def tight_bbox(greenness):
    """用略紧的阈值求人物包围盒（尽量不含外侧淡绿光晕，使缩放更稳）。"""
    mask = greenness <= TIGHT
    ys, xs = np.where(mask)
    return xs.min(), ys.min(), xs.max() + 1, ys.max() + 1


# ---------------- 对齐 ----------------
def ref_metrics():
    """从 idle.png 读出基准：画布尺寸、人物高度、脚底 y、水平中心 x。"""
    with open(os.path.join(ASSET_DIR, "manifest.json"), encoding="utf-8") as f:
        cw, ch = json.load(f)["size"]
    ref = np.asarray(Image.open(REF_PNG).convert("RGBA"))
    m = ref[..., 3] > 16
    ys, xs = np.where(m)
    return {
        "cw": cw, "ch": ch,
        "char_h": ys.max() - ys.min() + 1,
        "feet_y": ys.max() + 1,
        "cx": (xs.min() + xs.max()) // 2,
    }


def normalize(im_keyed, greenness, ref, scale):
    """按给定 scale 缩放并贴到 (cw, ch) 透明画布：脚底对齐、水平居中。
    会限制顶部裁切量（CLIP_BUDGET）和画布宽度，避免裁到头/发。"""
    x0, y0, x1, y1 = tight_bbox(greenness)
    char = im_keyed.crop((x0, y0, x1, y1))
    # 顶部裁切上限：内容底部贴脚底基线后，顶部最多超出画布 CLIP_BUDGET 像素
    max_h = ref["feet_y"] + CLIP_BUDGET
    if char.height * scale > max_h:
        scale = max_h / char.height
    new_w = max(1, round(char.width * scale))
    new_h = max(1, round(char.height * scale))
    if new_w > ref["cw"]:                 # 极端情况下别让长发被裁
        s2 = ref["cw"] / new_w
        new_w, new_h = ref["cw"], max(1, round(new_h * s2))
    char = char.resize((new_w, new_h), Image.LANCZOS)

    canvas = Image.new("RGBA", (ref["cw"], ref["ch"]), (0, 0, 0, 0))
    px = ref["cx"] - new_w // 2
    py = ref["feet_y"] - new_h            # 内容底部 = 脚底基线
    canvas.alpha_composite(char, (px, py))
    return canvas


def shared_scale(greenness, ref):
    """以站姿（吃东西）算出统一缩放系数，使其与 idle 身高一致。"""
    x0, y0, x1, y1 = tight_bbox(greenness)
    return ref["char_h"] / (y1 - y0)


def normalize_float(im_keyed, greenness, ref, scale, bottom_gap):
    """浮空姿势（盘腿打坐）：按 scale 缩放、水平居中，底部留出 bottom_gap 的留白
    （＝悬浮高度，双脚离地）。不对齐脚底基线；若长发比画布宽，最外侧发丝在两边裁掉
    （比把整个人缩小更好——保证头/身与 idle 等大）。"""
    x0, y0, x1, y1 = tight_bbox(greenness)
    char = im_keyed.crop((x0, y0, x1, y1))
    new_w = max(1, round(char.width * scale))
    new_h = max(1, round(char.height * scale))
    if new_h > ref["ch"]:                     # 高度兜底（正常不会触发）
        s2 = ref["ch"] / new_h
        new_w, new_h = max(1, round(new_w * s2)), ref["ch"]
    char = char.resize((new_w, new_h), Image.LANCZOS)
    canvas = Image.new("RGBA", (ref["cw"], ref["ch"]), (0, 0, 0, 0))
    px = ref["cx"] - new_w // 2
    py = max(0, ref["ch"] - bottom_gap - new_h)
    canvas.paste(char, (px, py), char)        # paste 会自动裁掉超出画布的外侧发丝
    return canvas


# ---------------- 合成循环帧 ----------------
def squash(img, sx, sy, ax, ay, dy=0.0):
    """绕锚点 (ax,ay) 做 sx/sy 缩放并整体平移 dy，画布尺寸不变（用于呼吸/点头）。"""
    W, H = img.size
    nw, nh = max(1, round(W * sx)), max(1, round(H * sy))
    scaled = img.resize((nw, nh), Image.LANCZOS)
    canvas = Image.new("RGBA", (W, H), (0, 0, 0, 0))
    px = round(ax * (1 - sx))
    py = round(ay * (1 - sy) + dy)
    canvas.alpha_composite(scaled, (px, py))
    return canvas


def make_meditate_loop(base, ref, n=6, amp=0.010, float_px=2.5):
    """浮空呼吸循环：绕人物中心极轻微纵向缩放 + 缓慢上下飘浮，首尾无缝衔接。
    （坐姿浮空，不踩地，所以绕中心而非脚底。）"""
    m = np.asarray(base)
    ys, xs = np.where(m[..., 3] > 16)
    cx = (xs.min() + xs.max()) // 2
    cy = (ys.min() + ys.max()) // 2
    frames = []
    for i in range(n):
        ph = 2 * math.pi * i / n
        breath = (1 - math.cos(ph)) / 2          # 0->1->0 呼吸
        sy = 1 + amp * breath
        sx = 1 - amp * 0.4 * breath
        drift = -float_px * math.sin(ph)          # 上下飘浮，整周期回到原位
        frames.append(squash(base, sx, sy, cx, cy, dy=drift))
    return frames


def make_eat_loop(open_img, close_img, ref):
    """咀嚼循环：张/闭嘴底图按节奏交替 + 1px 点头。"""
    plan = [  # (底图, 下沉 dy)  —— 咬一口后多嚼几下
        (open_img, 0),
        (open_img, 1),
        (close_img, 1),
        (close_img, 0),
        (close_img, 1),
        (open_img, 0),
    ]
    return [squash(img, 1.0, 1.0, ref["cx"], ref["feet_y"], dy=dy) for img, dy in plan]


# ---------------- 主流程 ----------------
def main(out_dir=ANIM_DIR, preview=False):
    os.makedirs(out_dir, exist_ok=True)
    ref = ref_metrics()
    print("基准 idle:", ref)

    norm = {}
    keyed = {}
    for name, fn in SOURCES.items():
        im = Image.open(os.path.join(SRC_DIR, fn))
        keyed[name] = chroma_key(im)            # (img, greenness)
    # 站姿（吃东西）按身高对齐 idle，作为基准缩放
    base = shared_scale(keyed["eat_open"][1], ref)
    print(f"站姿基准 scale={base:.4f}  |  修炼浮空 scale={MED_SCALE}")
    for name in SOURCES:
        img, greenness = keyed[name]
        if name == "meditate":
            norm[name] = normalize_float(img, greenness, ref, MED_SCALE, MED_BOTTOM_GAP)
            print(f"  规整 {name}（浮空，底部留白 {MED_BOTTOM_GAP}px）")
        else:
            sc = base * POSE_SCALE.get(name, 1.0)
            norm[name] = normalize(img, greenness, ref, sc)
            print(f"  规整 {name}  scale={sc:.4f}")

    med = make_meditate_loop(norm["meditate"], ref)
    eat = make_eat_loop(norm["eat_open"], norm["eat_close"], ref)

    for i, f in enumerate(med, 1):
        f.save(os.path.join(out_dir, f"meditate_{i:02d}.png"))
    for i, f in enumerate(eat, 1):
        f.save(os.path.join(out_dir, f"eat_{i:02d}.png"))
    print(f"已输出 {len(med)} 修炼帧 + {len(eat)} 吃东西帧 -> {out_dir}")
    return norm, med, eat, ref


if __name__ == "__main__":
    main()

